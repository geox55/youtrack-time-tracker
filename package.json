{
  "name": "toggl-youtrack-integration",
  "version": "1.0.0",
  "description": "Интеграция Toggl с YouTrack для трекинга времени",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "pnpm run test && pnpm run build && ./scripts/deploy.sh",
    "deploy-test": "pnpm run test && pnpm run build && ./scripts/deploy-test.sh",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.1",
    "axios": "^1.12.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-timezone-select": "^3.3.3",
    "react-toastify": "^11.0.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "jsdom": "^29.0.2",
    "typescript": "^5.3.3",
    "vite": "^8.0.8",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.4"
  }
}
